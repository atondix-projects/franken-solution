{
  "permissions": {
    "allow": [
      "mcp__Claude_Preview__preview_start",
      "mcp__figma-desktop__get_screenshot",
      "Bash(npm run:*)",
      "Bash(git log *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix $CLAUDE_FILE_PATHS 2>&1 || true"
          },
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -50"
          }
        ]
      }
    ]
  }
}
