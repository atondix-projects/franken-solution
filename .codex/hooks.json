{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix $CLAUDE_FILE_PATHS 2>&1 || true"
          },
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -50"
          }
        ]
      }
    ]
  }
}
